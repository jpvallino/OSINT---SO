# OSINT-SO Environment Variables
# Copy this file to .env and fill in your API keys

# Server
PORT=3001

# GitHub API (optional - increases rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=

# GNews API Key (free: https://gnews.io/)
GNEWS_API_KEY=

# Optional: Enable request logging
ENABLE_LOGGING=true
